# LOKAL GELİŞTİRME İÇİN (kendi bilgisayarında çalıştırırken)
# Aşağıdaki satırı aç:
DATABASE_URL="file:./dev.db"

# PRODUCTION (Vercel) İÇİN - Turso kullan:
# DATABASE_URL="libsql://veritabani-adi-kullanici.turso.io"
# DATABASE_AUTH_TOKEN="eyJ..."

# JWT - mutlaka değiştir, herhangi bir uzun rastgele string olsun
JWT_SECRET="degistir-bunu-kendi-gizli-anahtarinla-cok-uzun-olsun-12345abcdef"

# VERCEL BLOB (resim depolama) - sadece production için
# BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."
